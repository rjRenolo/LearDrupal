generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  apiKey    String?
  role      String   @default("student")  // "student" | "admin"
  progress  Progress[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Progress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phase       Int
  week        Int
  day         Int
  completedAt DateTime  @default(now())

  @@unique([userId, phase, week, day])
}

model Phase {
  id    Int    @id @default(autoincrement())
  order Int
  label String
  name  String
  color String
  bg    String
  weeks Week[]
}

model Week {
  id      Int    @id @default(autoincrement())
  phaseId Int
  order   Int
  label   String
  name    String
  phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  days    Day[]
}

model Day {
  id    Int    @id @default(autoincrement())
  weekId   Int
  order    Int
  dayLabel String
  title    String
  goal     String
  activityType  String
  activityTitle String?
  activityIntro String?
  aiPrompt    String?
  aiCheckGoal String?
  week      Week           @relation(fields: [weekId], references: [id], onDelete: Cascade)
  reading   ReadingItem[]
  questions QuizQuestion[]
  steps     HandsOnStep[]
  aiCheck   AiCheck?

  @@index([weekId])
}

model ReadingItem {
  id    Int     @id @default(autoincrement())
  dayId Int
  order Int
  title String
  body  String
  link  String?
  day   Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model QuizQuestion {
  id          Int    @id @default(autoincrement())
  dayId       Int
  order       Int
  q           String
  options     String
  answer      Int
  explanation String
  day         Day    @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model HandsOnStep {
  id    Int     @id @default(autoincrement())
  dayId Int
  order Int
  n     Int
  title String
  body  String?
  code  String?
  day   Day     @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model AiCheck {
  id        Int    @id @default(autoincrement())
  dayId     Int    @unique
  prompt    String
  checkGoal String
  day       Day    @relation(fields: [dayId], references: [id], onDelete: Cascade)
}
